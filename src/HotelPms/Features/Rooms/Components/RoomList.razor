@using HotelPms.Features.Rooms.Application
@using HotelPms.Features.Rooms.Domain
@using MudBlazor

<MudPaper Class="pa-0" Elevation="1">
    <MudTable T="RoomListItem"
              Items="Items"
              Dense="true"
              Hover="true"
              Elevation="0">
        <HeaderContent>
            <MudTh>Number</MudTh>
            <MudTh>Condition</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Number">
                <MudText Typo="Typo.body2">@context.Number</MudText>
            </MudTd>
            <MudTd DataLabel="Condition">
                <MudChip T="string" Color="@GetConditionColor(context.Condition)" Size="Size.Small">
                    @context.Condition
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Actions">
                <MudMenu Icon="@Icons.Material.Filled.MoreVert"
                         Size="Size.Small"
                         Dense="true">
                    <MudMenuItem Disabled="@(context.Condition == RoomCondition.Clean.ToString())"
                                 OnClick="@(() => RequestConditionChange(context.Id, RoomCondition.Clean))">
                        Mark clean
                    </MudMenuItem>
                    <MudMenuItem Disabled="@(context.Condition == RoomCondition.Dirty.ToString())"
                                 OnClick="@(() => RequestConditionChange(context.Id, RoomCondition.Dirty))">
                        Mark dirty
                    </MudMenuItem>
                    <MudMenuItem Disabled="@(context.Condition == RoomCondition.OutOfService.ToString())"
                                 OnClick="@(() => RequestConditionChange(context.Id, RoomCondition.OutOfService))">
                        Take out of service
                    </MudMenuItem>
                </MudMenu>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudStack AlignItems="AlignItems.Center" Class="pa-8" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.MeetingRoom" Color="Color.Secondary" Size="Size.Large" />
                <MudText Typo="Typo.subtitle1">No rooms yet</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Added rooms will appear here.
                </MudText>
            </MudStack>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    [Parameter]
    public IReadOnlyList<RoomListItem> Items { get; set; } = [];

    [Parameter]
    public EventCallback<UpdateRoomConditionRequest> ConditionChangeRequested { get; set; }

    private static Color GetConditionColor(string condition) =>
        condition switch
        {
            "Clean" => Color.Success,
            "Dirty" => Color.Warning,
            "OutOfService" => Color.Error,
            _ => Color.Default
        };

    private async Task RequestConditionChange(RoomId roomId, RoomCondition condition)
    {
        await ConditionChangeRequested.InvokeAsync(new UpdateRoomConditionRequest(roomId, condition));
    }
}
