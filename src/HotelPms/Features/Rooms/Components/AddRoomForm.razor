@using FluentValidation
@using HotelPms.Features.Rooms.Application
@using HotelPms.Shared.MultiTenancy
@using MudBlazor
@inject AddRoomHandler Handler
@inject ISnackbar Snackbar
@inject CurrentTenant CurrentTenant

<MudPaper Class="pa-4" Style="max-width: 480px;">
    <MudStack Spacing="3">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h6">Add room</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Create a physical room for the current workspace.
            </MudText>
        </MudStack>

        @if (!string.IsNullOrWhiteSpace(_validationMessage))
        {
            <MudAlert Severity="MudBlazor.Severity.Error" Dense="true">@_validationMessage</MudAlert>
        }

        <MudForm>
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_number"
                              Label="Room number"
                              Required="true"
                              Immediate="true" />

                <MudStack Row="true" Justify="Justify.FlexEnd">
                    <MudButton Color="Color.Primary"
                               Variant="Variant.Filled"
                               Disabled="_isSubmitting"
                               StartIcon="@Icons.Material.Filled.AddHome"
                               OnClick="SubmitAsync">
                        @(_isSubmitting ? "Adding..." : "Add room")
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudForm>
    </MudStack>
</MudPaper>

@code {
    [Parameter]
    public EventCallback RoomAdded { get; set; }

    private string _number = "";
    private string? _validationMessage;
    private bool _isSubmitting;

    private async Task SubmitAsync()
    {
        if (_isSubmitting)
        {
            return;
        }

        _isSubmitting = true;
        _validationMessage = null;

        try
        {
            var command = new AddRoomCommand(CurrentTenant.Id, _number);

            await Handler.HandleAsync(command);

            Snackbar.Add("Room added.", MudBlazor.Severity.Success);
            _number = "";
            await RoomAdded.InvokeAsync();
        }
        catch (ValidationException exception)
        {
            _validationMessage = exception.Errors.FirstOrDefault()?.ErrorMessage
                                 ?? "Please check the room details.";
            Snackbar.Add(_validationMessage, MudBlazor.Severity.Error);
        }
        catch (Exception)
        {
            _validationMessage = "Unable to add room.";
            Snackbar.Add(_validationMessage, MudBlazor.Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
