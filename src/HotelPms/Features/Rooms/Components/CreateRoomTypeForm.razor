@using FluentValidation
@using HotelPms.Features.Rooms.Application
@using HotelPms.Shared.MultiTenancy
@using MudBlazor
@inject CreateRoomTypeHandler Handler
@inject ISnackbar Snackbar
@inject CurrentTenant CurrentTenant

<MudPaper Class="pa-4" Style="max-width: 640px;">
    <MudStack Spacing="3">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h6">Create room type</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Define sellable room categories for the current workspace.
            </MudText>
        </MudStack>

        @if (!string.IsNullOrWhiteSpace(_validationMessage))
        {
            <MudAlert Severity="MudBlazor.Severity.Error" Dense="true">@_validationMessage</MudAlert>
        }

        <MudForm>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_code"
                                  Label="Code"
                                  Required="true"
                                  Immediate="true" />
                </MudItem>
                <MudItem xs="12" sm="8">
                    <MudTextField @bind-Value="_name"
                                  Label="Name"
                                  Required="true"
                                  Immediate="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="_baseOccupancy"
                                     Label="Base occupancy"
                                     Min="1"
                                     Immediate="true"
                                     Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="_maxOccupancy"
                                     Label="Max occupancy"
                                     Min="1"
                                     Immediate="true"
                                     Required="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudStack Row="true" Justify="Justify.FlexEnd">
                        <MudButton Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   Disabled="_isSubmitting"
                                   StartIcon="@Icons.Material.Filled.KingBed"
                                   OnClick="SubmitAsync">
                            @(_isSubmitting ? "Creating..." : "Create room type")
                        </MudButton>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudForm>
    </MudStack>
</MudPaper>

@code {
    [Parameter]
    public EventCallback RoomTypeCreated { get; set; }

    private string _code = "";
    private string _name = "";
    private int _baseOccupancy = 2;
    private int _maxOccupancy = 2;
    private string? _validationMessage;
    private bool _isSubmitting;

    private async Task SubmitAsync()
    {
        if (_isSubmitting)
        {
            return;
        }

        _isSubmitting = true;
        _validationMessage = null;

        try
        {
            var command = new CreateRoomTypeCommand(
                CurrentTenant.Id,
                _code,
                _name,
                _baseOccupancy,
                _maxOccupancy);

            await Handler.HandleAsync(command);

            Snackbar.Add("Room type created.", MudBlazor.Severity.Success);
            _code = "";
            _name = "";
            _baseOccupancy = 2;
            _maxOccupancy = 2;
            await RoomTypeCreated.InvokeAsync();
        }
        catch (ValidationException exception)
        {
            _validationMessage = exception.Errors.FirstOrDefault()?.ErrorMessage
                                 ?? exception.Message
                                 ?? "Please check the room type details.";
            Snackbar.Add(_validationMessage, MudBlazor.Severity.Error);
        }
        catch (Exception)
        {
            _validationMessage = "Unable to create room type.";
            Snackbar.Add(_validationMessage, MudBlazor.Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
