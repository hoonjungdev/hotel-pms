@page "/room-types"
@using HotelPms.Features.Rooms.Application
@using HotelPms.Features.Rooms.Components
@using HotelPms.Shared.MultiTenancy
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@inject ListRoomTypesHandler ListRoomTypesHandler
@inject ISnackbar Snackbar
@inject CurrentTenant CurrentTenant

<PageTitle>Room Types</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h4">Room Types</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Manage sellable room categories and occupancy limits.
            </MudText>
        </MudStack>

        <MudTooltip Text="Refresh room types">
            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                           Color="Color.Default"
                           Disabled="_isLoading"
                           OnClick="LoadRoomTypesAsync" />
        </MudTooltip>
    </MudStack>

    <CreateRoomTypeForm RoomTypeCreated="LoadRoomTypesAsync" />

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }

    @if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <MudAlert Severity="MudBlazor.Severity.Error" Dense="true">@_loadError</MudAlert>
    }

    <RoomTypeList Items="_roomTypes" />
</MudStack>

@code {
    private IReadOnlyList<RoomTypeListItem> _roomTypes = [];
    private string? _loadError;
    private bool _isLoading;

    protected override async Task OnInitializedAsync()
    {
        await LoadRoomTypesAsync();
    }

    private async Task LoadRoomTypesAsync()
    {
        if (_isLoading)
        {
            return;
        }

        _isLoading = true;
        _loadError = null;

        try
        {
            var query = new ListRoomTypesQuery(CurrentTenant.Id);
            _roomTypes = await ListRoomTypesHandler.HandleAsync(query);
        }
        catch
        {
            _loadError = "Unable to load room types.";
            Snackbar.Add(_loadError, MudBlazor.Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
