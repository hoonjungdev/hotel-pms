@page "/rooms"
@using HotelPms.Features.Rooms.Application
@using HotelPms.Features.Rooms.Components
@using HotelPms.Features.Rooms.Domain
@using HotelPms.Shared.MultiTenancy
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@inject ListRoomsHandler ListRoomsHandler
@inject ISnackbar Snackbar
@inject CurrentTenant CurrentTenant
@inject UpdateRoomConditionHandler UpdateRoomConditionHandler

<PageTitle>Rooms</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h4">Rooms</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Manage physical rooms for the current workspace.
            </MudText>
        </MudStack>

        <MudTooltip Text="Refresh rooms">
            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                           Color="Color.Default"
                           Disabled="_isLoading"
                           OnClick="LoadRoomsAsync" />
        </MudTooltip>
    </MudStack>

    <AddRoomForm RoomAdded="LoadRoomsAsync" />

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }

    @if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <MudAlert Severity="MudBlazor.Severity.Error" Dense="true">@_loadError</MudAlert>
    }

    <RoomList Items="_rooms" ConditionChangeRequested="UpdateRoomConditionAsync" />
</MudStack>

@code {
    private IReadOnlyList<RoomListItem> _rooms = [];
    private string? _loadError;
    private bool _isLoading;

    protected override async Task OnInitializedAsync()
    {
        await LoadRoomsAsync();
    }

    private async Task LoadRoomsAsync()
    {
        if (_isLoading)
        {
            return;
        }

        _isLoading = true;
        _loadError = null;

        try
        {
            var query = new ListRoomsQuery(CurrentTenant.Id);
            _rooms = await ListRoomsHandler.HandleAsync(query);
        }
        catch
        {
            _loadError = "Unable to load rooms.";
            Snackbar.Add(_loadError, MudBlazor.Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task UpdateRoomConditionAsync(UpdateRoomConditionRequest request)
    {
        try
        {
            var command = new UpdateRoomConditionCommand(
                CurrentTenant.Id,
                request.RoomId,
                request.Condition);

            await UpdateRoomConditionHandler.HandleAsync(command);
            Snackbar.Add("Room condition updated.", MudBlazor.Severity.Success);

            await LoadRoomsAsync();
        }
        catch
        {
            Snackbar.Add("Unable to update room condition.", MudBlazor.Severity.Error);
        }
    }
}
