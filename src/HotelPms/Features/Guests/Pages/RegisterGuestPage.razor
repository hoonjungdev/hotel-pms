@page "/guests/register"
@using HotelPms.Features.Guests.Components
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor

<PageTitle>Register Guest</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h4">Register Guest</MudText>
    <MudButton Href="/guests"
               Color="Color.Default"
               Variant="Variant.Outlined"
               StartIcon="@Icons.Material.Filled.ArrowBack">
        Guests
    </MudButton>
</MudStack>

<RegisterGuestForm />
