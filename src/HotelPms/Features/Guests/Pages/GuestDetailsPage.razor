@page "/guests/{GuestId:guid}"
@using HotelPms.Features.Guests.Application
@using HotelPms.Features.Guests.Domain
@using HotelPms.Shared.MultiTenancy
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@inject GetGuestHandler GetGuestHandler
@inject ISnackbar Snackbar
@inject CurrentTenant CurrentTenant

<PageTitle>Guest Details</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h4">Guest Details</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                View the selected guest profile.
            </MudText>
        </MudStack>

        <MudButton Href="/guests"
                   Color="Color.Default"
                   Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.ArrowBack">
            Guests
        </MudButton>
    </MudStack>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <MudAlert Severity="MudBlazor.Severity.Error" Dense="true">@_loadError</MudAlert>
    }
    else if (_guest is null)
    {
        <MudAlert Severity="MudBlazor.Severity.Warning" Dense="true">
            Guest was not found.
        </MudAlert>
    }
    else
    {
        <MudPaper Class="pa-4" Elevation="1">
            <MudStack Spacing="3">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.h5">@_guest.Name</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        ID: @_guest.Id
                    </MudText>
                </MudStack>

                <MudDivider />

                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Email</MudText>
                        <MudText Typo="Typo.body1">@FormatContact(_guest.Email)</MudText>
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Phone</MudText>
                        <MudText Typo="Typo.body1">@FormatContact(_guest.PhoneNumber)</MudText>
                    </MudItem>
                </MudGrid>
            </MudStack>
        </MudPaper>
    }
</MudStack>

@code {
    [Parameter]
    public Guid GuestId { get; set; }

    private GuestDetails? _guest;
    private string? _loadError;
    private bool _isLoading;

    protected override async Task OnParametersSetAsync()
    {
        await LoadGuestAsync();
    }

    private async Task LoadGuestAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            var query = new GetGuestQuery(CurrentTenant.Id, new GuestId(GuestId));
            _guest = await GetGuestHandler.HandleAsync(query);
        }
        catch
        {
            _loadError = "Unable to load guest.";
            Snackbar.Add(_loadError, MudBlazor.Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string FormatContact(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;
}
