@page "/guests"
@using HotelPms.Features.Guests.Application
@using HotelPms.Features.Guests.Components
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@inject ListGuestsHandler ListGuestsHandler
@inject ISnackbar Snackbar

<PageTitle>Guests</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h4">Guests</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                View guest profiles for the current workspace.
            </MudText>
        </MudStack>
        <MudStack Row="true" Spacing="2">
            <MudTooltip Text="Refresh guests">
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Color="Color.Default"
                               Disabled="_isLoading"
                               OnClick="LoadGuestsAsync" />
            </MudTooltip>
            <MudButton Href="/guests/register"
                       Color="Color.Primary"
                       Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.PersonAdd">
                Register
            </MudButton>
        </MudStack>
    </MudStack>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }

    @if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <MudAlert Severity="MudBlazor.Severity.Error" Dense="true">@_loadError</MudAlert>
    }

    <GuestList Items="_guests" />
</MudStack>

@code {
    private IReadOnlyList<GuestListItem> _guests = [];
    private string? _loadError;
    private bool _isLoading;

    protected override async Task OnInitializedAsync()
    {
        await LoadGuestsAsync();
    }

    private async Task LoadGuestsAsync()
    {
        if (_isLoading)
        {
            return;
        }

        _isLoading = true;
        _loadError = null;

        try
        {
            var query = new ListGuestsQuery(GuestWorkspaceTenant.Id);
            _guests = await ListGuestsHandler.HandleAsync(query);
        }
        catch
        {
            _loadError = "Unable to load guests.";
            Snackbar.Add(_loadError, MudBlazor.Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
