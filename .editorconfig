root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# 설정/마크업 파일은 2칸이 관용
[*.{json,yml,yaml,csproj,props,targets,slnx}]
indent_size = 2

[*.cs]

# ── 결정 1: file-scoped namespace ──
csharp_style_namespace_declarations = file_scoped:warning

# ── 결정 2: 타입이 명백할 때만 var ──
csharp_style_var_when_type_is_apparent = true:warning   # new Guest() → var OK
csharp_style_var_for_built_in_types = false:warning     # int 등은 명시
csharp_style_var_elsewhere = false:warning              # GetData() 반환은 명시

# ── 결정 3: expression-bodied는 프로퍼티/접근자만 ──
csharp_style_expression_bodied_properties = true:warning
csharp_style_expression_bodied_accessors = true:warning
csharp_style_expression_bodied_methods = false:silent
csharp_style_expression_bodied_constructors = false:silent

# ── 그 외 합리적 기본값 ──
csharp_prefer_braces = true:warning                     # if문 항상 중괄호 (dangling-if 버그 예방)
csharp_using_directive_placement = outside_namespace:warning
dotnet_style_qualification_for_field = false:warning    # this. 강요 안 함
dotnet_style_predefined_type_for_locals_parameters_members = true:warning  # Int32 대신 int
dotnet_sort_system_directives_first = true

# 인터페이스는 I 접두사
dotnet_naming_rule.interfaces_start_with_i.severity = warning
dotnet_naming_rule.interfaces_start_with_i.symbols = interface_symbols
dotnet_naming_rule.interfaces_start_with_i.style = i_prefix
dotnet_naming_symbols.interface_symbols.applicable_kinds = interface
dotnet_naming_style.i_prefix.capitalization = pascal_case
dotnet_naming_style.i_prefix.required_prefix = I

# private/internal 필드는 _camelCase
dotnet_naming_rule.private_fields_underscore.severity = warning
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_camel
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private, internal
dotnet_naming_style.underscore_camel.capitalization = camel_case
dotnet_naming_style.underscore_camel.required_prefix = _

# 사용하지 않는 using 경고
dotnet_diagnostic.IDE0005.severity = warning

# 불변성 — VO/Aggregate 설계의 핵심. 재할당 안 되는 필드인데
# readonly 안 붙었으면 경고. "불변식은 객체 안에서 보장" 철학과 직결
dotnet_style_readonly_field = true:warning

# 안 쓰는 매개변수 경고 (IDE0005가 using을 잡듯, 죽은 파라미터를 잡음)
dotnet_code_quality_unused_parameters = all:warning

# 불필요한 #pragma / SuppressMessage 경고 — 억제 위생
dotnet_remove_unnecessary_suppression_exclusions = none
dotnet_diagnostic.IDE0079.severity = warning

# 모던 C# 관용구 — 포트폴리오에서 코드가 세련되게 읽힘
dotnet_style_null_propagation = true:warning            # x?.Foo
dotnet_style_coalesce_expression = true:warning         # a ?? b
csharp_style_prefer_switch_expression = true:warning    # 이미 Money.cs에서 사용 중 → 일관성 강제
csharp_style_pattern_matching_over_is_with_cast_expression = true:warning
